<%- include('partials/head') %>
<%- include('partials/header') %>

<!-- HERO -->
<section class="hero">
  <div class="hero__bg-image">
    <img src="/images/hero-bg.jpg" alt="Imóvel de luxo" onerror="this.style.display='none'">
  </div>
  <div class="hero__bg"></div>
  <div class="container">
    <div class="hero__content fade-in">
      <div class="hero__eyebrow">Tradição Imóveis · Desde 1994</div>
      <h1 class="hero__title">
        Encontre onde sua<br>
        <em>história</em> começa
      </h1>
      <div class="hero__bar"></div>
      <p class="hero__subtitle">Curadoria exclusiva de imóveis em Maringá e região. Mais de três décadas conectando famílias a lares extraordinários.</p>
      <div class="hero__actions">
        <a href="/imoveis" class="btn btn--primary">Ver Imóveis</a>
        <a href="/contato" class="btn btn--secondary" style="color:rgba(245,240,232,0.85);border-color:rgba(245,240,232,0.25);">Fale Conosco</a>
      </div>
    </div>
  </div>
  <div class="hero__scroll">
    <div class="hero__scroll-icon">
      <span></span>
      <span></span>
    </div>
  </div>
</section>

<!-- DESTAQUE -->
<% if (destaque) { %>
<section class="destaque-section">
  <div class="container">
    <div class="section__header fade-in">
      <h2 class="section__title--destaque">Imóvel em <em>Destaque</em></h2>
    </div>

    <a href="/imovel/<%= destaque.id %>" class="lg-card fade-in" id="lgCard">

      <!-- Imagem de fundo -->
      <div class="lg-card__bg">
        <% if (destaque.foto_principal) { %>
          <img src="<%= destaque.foto_principal %>" alt="<%= destaque.titulo %>">
        <% } else { %>
          <div class="lg-card__bg-placeholder">🏠</div>
        <% } %>
      </div>

      <!-- Overlay escuro gradiente -->
      <div class="lg-card__overlay"></div>

      <!-- Luz que segue o mouse -->
      <div class="lg-card__light" id="lgLight"></div>

      <!-- Painel glass -->
      <div class="lg-card__glass" id="lgGlass">
        <!-- Reflexo especular do glass -->
        <div class="lg-card__glass-shine" id="lgShine"></div>

        <div class="lg-card__glass-content">
          <div class="lg-card__tags">
            <span class="lg-tag">Destaque</span>
            <% if (destaque.categoria_nome) { %>
              <span class="lg-tag lg-tag--muted"><%= destaque.categoria_nome %></span>
            <% } %>
          </div>

          <h2 class="lg-card__title"><%= destaque.titulo %></h2>

          <% if (destaque.bairro || destaque.cidade) { %>
          <p class="lg-card__location">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            <%= [destaque.bairro, destaque.cidade, destaque.estado].filter(Boolean).join(', ') %>
          </p>
          <% } %>

          <div class="lg-card__specs">
            <% if (destaque.quartos > 0) { %>
            <div class="lg-spec">
              <span class="lg-spec__value"><%= destaque.quartos %></span>
              <span class="lg-spec__label">Quartos</span>
            </div>
            <% } %>
            <% if (destaque.banheiros > 0) { %>
            <div class="lg-spec">
              <span class="lg-spec__value"><%= destaque.banheiros %></span>
              <span class="lg-spec__label">Banheiros</span>
            </div>
            <% } %>
            <% if (destaque.area_total) { %>
            <div class="lg-spec">
              <span class="lg-spec__value"><%= Math.round(destaque.area_total) %>m²</span>
              <span class="lg-spec__label">Área Total</span>
            </div>
            <% } %>
            <% if (destaque.vagas_garagem > 0) { %>
            <div class="lg-spec">
              <span class="lg-spec__value"><%= destaque.vagas_garagem %></span>
              <span class="lg-spec__label">Vagas</span>
            </div>
            <% } %>
          </div>

          <div class="lg-card__footer">
            <div class="lg-card__price"><%= destaque.preco_formatado %></div>
            <span class="lg-card__cta">Clique para saber mais</span>
          </div>
        </div>
      </div>

    </a>
  </div>
</section>

<script>
(function () {
  const card  = document.getElementById('lgCard');
  const light = document.getElementById('lgLight');
  const shine = document.getElementById('lgShine');
  if (!card || !light || !shine) return;

  let raf;

  card.addEventListener('mousemove', (e) => {
    cancelAnimationFrame(raf);
    raf = requestAnimationFrame(() => {
      const r  = card.getBoundingClientRect();
      const x  = e.clientX - r.left;
      const y  = e.clientY - r.top;
      const xp = (x / r.width)  * 100;
      const yp = (y / r.height) * 100;

      // luz principal — segue o mouse em toda a superfície do card
      light.style.background = `radial-gradient(
        520px circle at ${x}px ${y}px,
        rgba(255,255,255,0.13) 0%,
        rgba(255,255,255,0.04) 35%,
        transparent 65%
      )`;

      // reflexo especular no painel glass — varia com posição X do mouse
      const glassR = document.getElementById('lgGlass').getBoundingClientRect();
      const gx = e.clientX - glassR.left;
      const gy = e.clientY - glassR.top;
      shine.style.background = `radial-gradient(
        280px circle at ${gx}px ${gy}px,
        rgba(255,255,255,0.22) 0%,
        rgba(255,255,255,0.06) 40%,
        transparent 70%
      )`;

      // tilt sutil do card
      const tiltX = ((yp - 50) / 50) * -4;
      const tiltY = ((xp - 50) / 50) *  4;
      card.style.transform = `perspective(1200px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) scale(1.01)`;
    });
  });

  card.addEventListener('mouseleave', () => {
    cancelAnimationFrame(raf);
    light.style.background = 'none';
    shine.style.background = 'none';
    card.style.transform = 'perspective(1200px) rotateX(0deg) rotateY(0deg) scale(1)';
  });
})();
</script>
<% } %>

<!-- CURADORIA -->
<% if (categorias && categorias.length > 0) { %>
<section class="curadoria-section">
  <div class="container">
    <div class="section__header fade-in">
      <div class="section__eyebrow">Nossas Especialidades</div>
      <h2 class="section__title">Nossa Curadoria</h2>
      <p class="section__subtitle">Selecionamos as melhores oportunidades em cada segmento para você.</p>
    </div>
    <div class="bento-grid fade-in">
      <% categorias.forEach(function(cat) { %>
      <a href="/imoveis?categoria_id=<%= cat.id %>" class="bento-item">
        <% if (cat.imagem_url) { %>
          <img src="<%= cat.imagem_url %>" alt="<%= cat.nome %>" onerror="this.parentElement.style.background='var(--surface-container-highest)'">
        <% } else { %>
          <div style="width:100%;height:100%;background:var(--surface-container-highest);"></div>
        <% } %>
        <div class="bento-item__overlay">
          <div class="bento-item__badge"><%= cat.subtitulo || '' %></div>
          <div class="bento-item__title"><%= cat.nome %></div>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- CTA BAND -->
<section style="background:linear-gradient(135deg,var(--primary),var(--primary-container));padding:var(--space-4xl) 0;">
  <div class="container" style="text-align:center;">
    <div class="badge" style="background:rgba(255,154,145,0.2);color:var(--on-primary-container);margin-bottom:1.5rem;">Atendimento Personalizado</div>
    <h2 style="font-family:var(--font-serif);font-size:var(--headline-lg);color:var(--on-primary);font-weight:300;margin-bottom:1rem;">
      Prontos para encontrar<br>o imóvel ideal para você
    </h2>
    <p style="color:rgba(255,255,255,0.75);font-size:1.125rem;max-width:50ch;margin:0 auto 2rem;">
      Nossa equipe de especialistas está disponível para tornar sua busca mais eficiente e segura.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/contato" class="btn" style="background:var(--on-primary);color:var(--primary);border-radius:var(--radius-xs);">Fale Conosco</a>
      <a href="https://wa.me/5544998870006" target="_blank" class="btn btn--secondary" style="color:var(--on-primary);border-color:rgba(255,255,255,0.3);">WhatsApp</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<script src="/js/main.js"></script>
</body>
</html>
