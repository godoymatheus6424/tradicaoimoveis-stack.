<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { active: 'condominios' }) %>
  <main class="admin-main">
    <div class="admin-topbar">
      <div class="admin-topbar__title"><%= condominio ? 'Editar Condomínio' : 'Novo Condomínio' %></div>
      <div class="admin-topbar__user">
        <%= adminNome %> &nbsp;·&nbsp;
        <a href="/auth/admin/logout" style="color:var(--primary);font-weight:600;">Sair</a>
      </div>
    </div>
    <div class="admin-content">
      <% if (errors && errors.length > 0) { %>
      <div class="alert alert--error">
        <% errors.forEach(function(e) { %><div>• <%= e %></div><% }) %>
      </div>
      <% } %>

      <form
        method="POST"
        action="<%= condominio ? '/admin/condominios/' + condominio.id + '?_method=PUT' : '/admin/condominios' %>"
        enctype="multipart/form-data"
      >
        <% if (condominio && condominio.id) { %>
          <input type="hidden" name="_method" value="PUT">
        <% } %>

        <div class="admin-form">
          <h3 style="font-family:var(--font-serif);font-size:var(--title-lg);margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid var(--surface-container-high);">Informações Básicas</h3>

          <div class="admin-form__grid">
            <div class="admin-form__full">
              <label class="input-label">Nome *</label>
              <input type="text" name="nome" class="input" required value="<%= condominio ? condominio.nome : '' %>" placeholder="Ex: Condomínio Residencial Park Life">
            </div>

            <div>
              <label class="input-label">Valor (R$)</label>
              <div style="display:flex;align-items:center;gap:0.75rem;">
                <input type="hidden" id="valorHidden" name="valor" value="<%= condominio ? condominio.valor : '' %>">
                <input type="number" id="valorInput" class="input" step="0.01" min="0" value="<%= condominio && Number(condominio.valor) !== 0 ? condominio.valor : '' %>" placeholder="Ex: 1500" style="flex:1;" oninput="document.getElementById('valorHidden').value=this.value" <%= (condominio && Number(condominio.valor) === 0) ? 'disabled' : '' %>>
                <label style="display:flex;align-items:center;gap:0.4rem;white-space:nowrap;cursor:pointer;font-size:var(--label-sm);color:var(--on-surface-variant);">
                  <input type="checkbox" id="sobConsultaCheck" name="sob_consulta" onchange="toggleSobConsulta(this)" <%= (condominio && Number(condominio.valor) === 0) ? 'checked' : '' %>>
                  Sob consulta
                </label>
              </div>
            </div>

            <div class="admin-form__full">
              <label class="input-label">Descrição</label>
              <textarea name="descricao" class="input" rows="5" placeholder="Descreva o condomínio..."><%= condominio ? condominio.descricao || '' : '' %></textarea>
            </div>

            <div class="admin-form__full">
              <label class="input-label">Características</label>
              <textarea name="caracteristicas" class="input" rows="4" placeholder="Ex: Academia, Piscina, Salão de festas, Portaria 24h..."><%= condominio ? condominio.caracteristicas || '' : '' %></textarea>
            </div>
          </div>

          <h3 style="font-family:var(--font-serif);font-size:var(--title-lg);margin:1.5rem 0 1.5rem;padding:1rem 0;border-top:1px solid var(--surface-container-high);border-bottom:1px solid var(--surface-container-high);">Localização</h3>

          <div class="admin-form__grid">
            <div class="admin-form__full">
              <label class="input-label">Endereço</label>
              <input type="text" name="endereco" class="input" value="<%= condominio ? condominio.endereco || '' : '' %>" placeholder="Rua, número">
            </div>
            <div>
              <label class="input-label">Bairro</label>
              <input type="text" name="bairro" class="input" value="<%= condominio ? condominio.bairro || '' : '' %>">
            </div>
            <div>
              <label class="input-label">Cidade</label>
              <input type="text" name="cidade" class="input" value="<%= condominio ? condominio.cidade || 'Maringá' : 'Maringá' %>">
            </div>
            <div>
              <label class="input-label">Estado</label>
              <input type="text" name="estado" class="input" maxlength="2" value="<%= condominio ? condominio.estado || 'PR' : 'PR' %>">
            </div>
            <div>
              <label class="input-label">CEP</label>
              <input type="text" name="cep" class="input" value="<%= condominio ? condominio.cep || '' : '' %>" placeholder="00000-000">
            </div>
          </div>

          <!-- Fotos existentes -->
          <% if (fotos && fotos.length > 0) { %>
          <h3 style="font-family:var(--font-serif);font-size:var(--title-lg);margin:1.5rem 0 1rem;padding-top:1rem;border-top:1px solid var(--surface-container-high);">Fotos Atuais</h3>
          <div class="upload-preview" id="fotosAtuais">
            <% fotos.forEach(function(foto) { %>
            <div class="upload-preview__item" id="cfoto-<%= foto.id %>">
              <img src="<%= foto.path %>" alt="">
              <% if (foto.principal) { %>
              <div class="upload-preview__star">✓ Principal</div>
              <% } %>
              <button type="button" class="upload-preview__del" onclick="deletarFotoCondominio(<%= foto.id %>)">✕</button>
            </div>
            <% }) %>
          </div>
          <% } %>

          <!-- Upload novas fotos -->
          <div style="margin-top:1.5rem;border-top:1px solid var(--surface-container-high);padding-top:1.5rem;">
            <label class="input-label" style="margin-bottom:1rem;">Adicionar Fotos</label>
            <div class="upload-area" onclick="document.getElementById('fotosInput').click()">
              <div class="upload-area__icon">📷</div>
              <div class="upload-area__text">
                Clique ou arraste fotos aqui<br>
                <small style="color:var(--outline);">JPG, PNG, WEBP · máx 10MB · até 20 fotos</small>
              </div>
              <input type="file" id="fotosInput" name="fotos" multiple accept=".jpg,.jpeg,.png,.webp" style="display:none;" onchange="previewFotos(this)">
            </div>
            <div class="upload-preview" id="previewNovos"></div>
          </div>

          <div style="display:flex;gap:1rem;margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--surface-container-high);">
            <button type="submit" class="btn btn--primary"><%= condominio ? 'Salvar Alterações' : 'Cadastrar Condomínio' %></button>
            <a href="/admin/condominios" class="btn btn--secondary">Cancelar</a>
          </div>
        </div>
      </form>
    </div>
  </main>
</div>
<script src="/js/admin.js"></script>
<script>
function toggleSobConsulta(cb) {
  const input = document.getElementById('valorInput');
  const hidden = document.getElementById('valorHidden');
  if (cb.checked) {
    input.dataset.prevValue = input.value;
    input.value = '';
    input.disabled = true;
    hidden.value = '0';
  } else {
    input.value = input.dataset.prevValue || '';
    input.disabled = false;
    hidden.value = input.value;
    input.focus();
  }
}

async function deletarFotoCondominio(id) {
  if (!confirm('Remover esta foto?')) return;
  try {
    const res = await fetch(`/admin/condominio-fotos/${id}?_method=DELETE`, { method: 'POST' });
    const json = await res.json();
    if (json.success) document.getElementById('cfoto-' + id).remove();
    else alert('Erro ao remover foto.');
  } catch (e) { alert('Erro de rede.'); }
}
</script>
</body>
</html>
