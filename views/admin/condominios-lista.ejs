<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { active: 'condominios' }) %>
  <main class="admin-main">
    <div class="admin-topbar">
      <div class="admin-topbar__title">Condomínios</div>
      <div class="admin-topbar__user">
        <%= adminNome %> &nbsp;·&nbsp;
        <a href="/auth/admin/logout" style="color:var(--primary);font-weight:600;">Sair</a>
      </div>
    </div>
    <div class="admin-content">

      <!-- Barra de ações em lote -->
      <div id="bulkBar" style="display:none;align-items:center;gap:1rem;background:var(--surface-container-high);border-radius:var(--radius-sm);padding:0.75rem 1rem;margin-bottom:1rem;">
        <span id="bulkCount" style="font-weight:600;color:var(--on-surface-variant);font-size:var(--label-md);"></span>
        <button onclick="excluirSelecionados()" class="btn btn--sm" style="background:var(--error);color:#fff;border:none;">Excluir selecionados</button>
        <button onclick="desmarcarTodos()" class="btn btn--secondary btn--sm">Cancelar</button>
      </div>

      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
        <div style="font-size:var(--label-md);color:var(--on-surface-variant);"><%= condominios.length %> condomínio(s) cadastrado(s)</div>
        <div style="display:flex;gap:0.5rem;">
          <button onclick="selecionarTodos()" class="btn btn--secondary btn--sm">Selecionar todos</button>
          <a href="/admin/condominios/novo" class="btn btn--primary btn--sm">+ Novo Condomínio</a>
        </div>
      </div>

      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Foto</th>
              <th>Nome</th>
              <th>Localização</th>
              <th>Valor</th>
              <th>Status</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% condominios.forEach(function(c) { %>
            <tr id="row-<%= c.id %>" style="transition:background .15s;">
              <td>
                <% if (c.foto_principal) { %>
                  <img class="admin-table__thumb" src="<%= c.foto_principal %>" alt="">
                <% } else { %>
                  <div style="width:48px;height:36px;background:var(--surface-container-high);border-radius:var(--radius-xs);display:flex;align-items:center;justify-content:center;">🏢</div>
                <% } %>
              </td>
              <td>
                <strong><%= c.nome %></strong><br>
                <span style="font-size:var(--label-sm);color:var(--on-surface-variant);">#<%= String(c.id).padStart(4,'0') %></span>
              </td>
              <td><%= [c.bairro, c.cidade].filter(Boolean).join(' — ') || '—' %></td>
              <td><%= c.valor_formatado %></td>
              <td>
                <span class="status <%= c.ativo ? 'status--active' : 'status--inactive' %>">
                  <%= c.ativo ? 'Ativo' : 'Inativo' %>
                </span>
              </td>
              <td>
                <div class="action-btns" style="gap:0.25rem;">
                  <a href="/admin/condominios/<%= c.id %>/editar" class="action-btn action-btn--edit" title="Editar" style="padding:0.35rem 0.5rem;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </a>
                  <button onclick="excluirCondominio(<%= c.id %>)" class="action-btn action-btn--delete" title="Excluir" style="padding:0.35rem 0.5rem;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                  </button>
                  <button onclick="toggleSelecionado(<%= c.id %>, this)" class="action-btn" id="sel-<%= c.id %>" style="padding:0.35rem 0.6rem;font-size:var(--label-sm);background:var(--surface-container-high);color:var(--on-surface-variant);border:none;">Selecionar</button>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<script src="/js/admin.js"></script>
<script>
const _selecionados = new Set();

function toggleSelecionado(id, btn) {
  const row = document.getElementById('row-' + id);
  if (_selecionados.has(id)) {
    _selecionados.delete(id);
    row.style.background = '';
    btn.textContent = 'Selecionar';
    btn.style.background = 'var(--surface-container-high)';
    btn.style.color = 'var(--on-surface-variant)';
  } else {
    _selecionados.add(id);
    row.style.background = 'var(--surface-container-high)';
    btn.textContent = 'Selecionado';
    btn.style.background = 'var(--primary)';
    btn.style.color = '#fff';
  }
  atualizarBulkBar();
}

function selecionarTodos() {
  document.querySelectorAll('[id^="sel-"]').forEach(btn => {
    const id = parseInt(btn.id.replace('sel-', ''));
    if (!_selecionados.has(id)) toggleSelecionado(id, btn);
  });
}

function desmarcarTodos() {
  _selecionados.forEach(id => {
    const row = document.getElementById('row-' + id);
    const btn = document.getElementById('sel-' + id);
    if (row) row.style.background = '';
    if (btn) { btn.textContent = 'Selecionar'; btn.style.background = 'var(--surface-container-high)'; btn.style.color = 'var(--on-surface-variant)'; }
  });
  _selecionados.clear();
  atualizarBulkBar();
}

function atualizarBulkBar() {
  const bar = document.getElementById('bulkBar');
  const count = document.getElementById('bulkCount');
  if (_selecionados.size > 0) {
    bar.style.display = 'flex';
    count.textContent = _selecionados.size === 1 ? '1 condomínio selecionado' : `${_selecionados.size} condomínios selecionados`;
  } else {
    bar.style.display = 'none';
  }
}

async function excluirCondominio(id) {
  if (!confirm('Excluir este condomínio? Esta ação não pode ser desfeita.')) return;
  try {
    const res = await fetch(`/admin/condominios/${id}?_method=DELETE`, { method: 'POST' });
    const json = await res.json();
    if (json.success) document.getElementById('row-' + id).remove();
    else alert('Erro: ' + (json.error || 'Falha ao excluir.'));
  } catch (e) { alert('Erro de rede.'); }
}

async function excluirSelecionados() {
  const ids = Array.from(_selecionados);
  if (!ids.length) return;
  if (!confirm(`Excluir ${ids.length} condomínio(s)? Esta ação não pode ser desfeita.`)) return;
  for (const id of ids) {
    try {
      const res = await fetch(`/admin/condominios/${id}?_method=DELETE`, { method: 'POST' });
      const json = await res.json();
      if (json.success) document.getElementById('row-' + id).remove();
    } catch (e) {}
  }
  _selecionados.clear();
  atualizarBulkBar();
}
</script>
</body>
</html>
