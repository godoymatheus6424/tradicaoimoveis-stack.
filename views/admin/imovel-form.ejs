<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/admin.css">
  <script>window._csrf='<%= csrfToken() %>';</script>
</head>
<body class="admin-body">
<div class="admin-layout">
  <%- include('../partials/admin-sidebar', { active: 'imoveis' }) %>
  <main class="admin-main">
    <div class="admin-topbar">
      <div class="admin-topbar__title"><%= imovel ? 'Editar Imóvel' : 'Novo Imóvel' %></div>
      <div class="admin-topbar__user">
        <%= adminNome %> &nbsp;·&nbsp;
        <a href="/auth/admin/logout" style="color:var(--primary);font-weight:600;">Sair</a>
      </div>
    </div>
    <div class="admin-content">
      <% if (errors && errors.length > 0) { %>
      <div class="alert alert--error">
        <% errors.forEach(function(e) { %><div>• <%= e %></div><% }) %>
      </div>
      <% } %>

      <!-- Upload de pasta do imóvel -->
      <div class="admin-form" style="margin-bottom:1.5rem;background:var(--surface-container-low);border:1.5px dashed var(--outline-variant);border-radius:var(--radius-md);padding:1.5rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
          <div>
            <div style="font-weight:600;margin-bottom:0.25rem;">Importar pasta do imóvel</div>
            <div style="font-size:var(--label-sm);color:var(--on-surface-variant);">Selecione a pasta do imóvel — ela pode conter um PDF ou DOCX com as informações e as fotos. Os campos serão preenchidos automaticamente e você escolhe a foto principal.</div>
          </div>
          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
            <label class="btn btn--primary btn--sm" style="cursor:pointer;display:inline-flex;align-items:center;gap:0.5rem;">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
              Carregar pasta
              <input type="file" id="pastaInput" webkitdirectory multiple style="display:none;" onchange="processarPasta(this)">
            </label>
            <label class="btn btn--secondary btn--sm" style="cursor:pointer;display:inline-flex;align-items:center;gap:0.5rem;">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              Só a ficha (PDF/DOCX)
              <input type="file" id="fichaInput" accept=".pdf,.docx" style="display:none;" onchange="processarFicha(this)">
            </label>
          </div>
        </div>
        <div id="fichaStatus" style="display:none;margin-top:1rem;padding:0.75rem 1rem;border-radius:var(--radius-sm);font-size:var(--label-sm);"></div>

        <!-- Preview das fotos da pasta -->
        <div id="pastaFotosWrap" style="display:none;margin-top:1.25rem;">
          <div style="font-size:var(--label-sm);font-weight:600;margin-bottom:0.75rem;color:var(--on-surface-variant);">FOTOS ENCONTRADAS — clique para definir a principal</div>
          <div id="pastaFotosGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:10px;"></div>
        </div>
      </div>

      <form
        method="POST"
        action="<%= imovel ? '/admin/imoveis/' + imovel.id + '?_method=PUT&_csrf=' + csrfToken() : '/admin/imoveis?_csrf=' + csrfToken() %>"
        enctype="multipart/form-data"
      >
        <% if (imovel && imovel.id) { %>
          <input type="hidden" name="_method" value="PUT">
        <% } %>

        <!-- Fotos e Upload -->
        <div class="admin-form" style="margin-bottom:1.5rem;" id="uploadFotosManual">
          <h3 style="font-family:var(--font-serif);font-size:var(--title-lg);margin-bottom:1rem;padding-bottom:1rem;border-bottom:1px solid var(--surface-container-high);">Fotos</h3>

          <input type="hidden" name="fotos_ordem" id="fotosOrdemInput">

          <div class="upload-preview" id="fotosAtuais">
            <% if (typeof fotos !== 'undefined' && fotos && fotos.length > 0) { %>
              <% fotos.forEach(function(foto, idx) { %>
              <div class="upload-preview__item foto-drag-item" id="foto-<%= foto.id %>" draggable="true">
                <img src="<%= foto.path %>" alt="">
                <div class="foto-principal-badge<%= idx === 0 ? ' foto-principal-badge--on' : '' %>">PRINCIPAL</div>
                <button type="button" class="upload-preview__del" onclick="deletarFoto('<%= foto.id %>')">✕</button>
              </div>
              <% }) %>
            <% } %>

            <!-- Botão de Upload estilo quadrado + -->
            <div class="upload-preview__item upload-add-btn" onclick="document.getElementById('fotosInput').click()" style="display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.02);border:2px dashed var(--outline-variant);cursor:pointer;transition:all 0.3s ease;">
              <span style="font-size:2.5rem;color:var(--outline-variant);font-weight:300;">+</span>
            </div>
          </div>

          <input type="file" id="fotosInput" name="fotos" multiple accept=".jpg,.jpeg,.png,.webp" style="display:none;" onchange="previewFotos(this)">
          <div class="upload-preview" id="previewNovos" style="margin-top:1rem;"></div>
        </div>

        <div class="admin-form">
          <h3 style="font-family:var(--font-serif);font-size:var(--title-lg);margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid var(--surface-container-high);">Informações Básicas</h3>

          <div class="admin-form__grid">
            <div class="admin-form__full">
              <label class="input-label">Título *</label>
              <input type="text" name="titulo" class="input" required value="<%= imovel ? imovel.titulo : '' %>" placeholder="Ex: Casa com 4 suítes no Jardim Alvorada">
            </div>
            <div>
              <label class="input-label">Tipo *</label>
              <select name="tipo" class="input" required>
                <option value="">Selecione</option>
                <% [
                  ['Casa',           'Casa'],
                  ['Sobrado',        'Sobrado'],
                  ['Apartamento',    'Apartamento'],
                  ['Terreno',        'Terreno'],
                  ['Galpão/Barracão','Galpão/Barracão'],
                  ['Sala/Salão',     'Sala/Salão'],
                  ['Fazenda',        'Fazenda'],
                  ['rural',          'Rural (legado)'],
                  ['Cobertura',      'Cobertura'],
                ].forEach(function([val, label]) { %>
                <option value="<%= val %>" <%= imovel && imovel.tipo === val ? 'selected' : '' %>><%= label %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label class="input-label">Finalidade *</label>
              <select name="finalidade" class="input" required>
                <option value="venda" <%= !imovel || imovel.finalidade === 'venda' ? 'selected' : '' %>>Venda</option>
                <option value="aluguel" <%= imovel && imovel.finalidade === 'aluguel' ? 'selected' : '' %>>Aluguel</option>
              </select>
            </div>
            <div>
              <label class="input-label">Preço (R$)</label>
              <div style="display:flex;align-items:center;gap:0.75rem;">
                <input type="hidden" id="precoHidden" name="preco" value="<%= imovel ? imovel.preco : '' %>">
                <input type="number" id="precoInput" class="input" step="0.01" min="0" value="<%= imovel ? imovel.preco : '' %>" placeholder="Ex: 850000" style="flex:1;" oninput="document.getElementById('precoHidden').value=this.value" <%= (imovel && Number(imovel.preco) === 0) ? 'disabled' : '' %>>
                <label style="display:flex;align-items:center;gap:0.4rem;white-space:nowrap;cursor:pointer;font-size:var(--label-sm);color:var(--on-surface-variant);">
                  <input type="checkbox" id="sobConsultaCheck" onchange="toggleSobConsulta(this)" <%= (imovel && Number(imovel.preco) === 0) ? 'checked' : '' %>>
                  Sob consulta
                </label>
              </div>
            </div>
            <div>
              <label class="input-label">Preço do Condomínio (R$)</label>
              <div style="display:flex;align-items:center;gap:0.75rem;">
                <input type="hidden" id="condominioHidden" name="valor_condominio" value="<%= imovel && imovel.valor_condominio !== null ? imovel.valor_condominio : '' %>">
                <input type="number" id="condominioInput" class="input" step="0.01" min="0" value="<%= imovel && imovel.valor_condominio !== null ? imovel.valor_condominio : '' %>" placeholder="Ex: 500" style="flex:1;" oninput="document.getElementById('condominioHidden').value=this.value" <%= (!imovel || imovel.valor_condominio === null) ? 'disabled' : '' %>>
                <label style="display:flex;align-items:center;gap:0.4rem;white-space:nowrap;cursor:pointer;font-size:var(--label-sm);color:var(--on-surface-variant);">
                  <input type="checkbox" name="sem_condominio" id="semCondominioCheck" onchange="toggleSemCondominio(this)" <%= (!imovel || imovel.valor_condominio === null) ? 'checked' : '' %>>
                  Sem condomínio
                </label>
              </div>
            </div>
            <div>
              <label class="input-label">Categoria</label>
              <select name="categoria_id" class="input">
                <option value="">Sem categoria</option>
                <% categorias.forEach(function(cat) { %>
                <option value="<%= cat.id %>" <%= imovel && imovel.categoria_id == cat.id ? 'selected' : '' %>><%= cat.nome %></option>
                <% }) %>
              </select>
            </div>
            <div class="admin-form__full">
              <label class="input-label">Descrição</label>
              <textarea name="descricao" class="input" rows="5" placeholder="Descreva o imóvel..."><%= imovel ? imovel.descricao || '' : '' %></textarea>
            </div>
          </div>

          <h3 style="font-family:var(--font-serif);font-size:var(--title-lg);margin:1.5rem 0 1.5rem;padding:1rem 0;border-top:1px solid var(--surface-container-high);border-bottom:1px solid var(--surface-container-high);">Características</h3>

          <div class="admin-form__grid">
            <div>
              <label class="input-label">Área Total</label>
              <div style="display:flex;gap:6px;align-items:center;">
                <input type="number" id="areaTotal_display" class="input" step="0.01" min="0"
                  value="<%= imovel && imovel.area_total ? (imovel.unidade_area === 'ha' ? (imovel.area_total / 10000).toFixed(4) : imovel.area_total) : '' %>"
                  style="flex:1;" oninput="syncArea('total')">
                <select id="areaTotal_unit" class="input" style="width:72px;flex-shrink:0;" onchange="syncArea('total')">
                  <option value="m2" <%= !imovel || imovel.unidade_area !== 'ha' ? 'selected' : '' %>>m²</option>
                  <option value="ha" <%= imovel && imovel.unidade_area === 'ha' ? 'selected' : '' %>>ha</option>
                </select>
              </div>
              <input type="hidden" name="area_total" id="area_total_hidden"
                value="<%= imovel ? imovel.area_total || '' : '' %>">
              <input type="hidden" name="unidade_area" id="unidade_area_hidden"
                value="<%= imovel ? imovel.unidade_area || 'm2' : 'm2' %>">
            </div>
            <div>
              <label class="input-label">Área Construída (m²)</label>
              <input type="number" name="area_construida" class="input" step="0.01" min="0" value="<%= imovel ? imovel.area_construida || '' : '' %>">
            </div>
            <div>
              <label class="input-label">Quartos</label>
              <input type="number" name="quartos" class="input" min="0" value="<%= imovel ? imovel.quartos || 0 : 0 %>">
            </div>
            <div>
              <label class="input-label">Suítes</label>
              <input type="number" name="suites" class="input" min="0" value="<%= imovel ? imovel.suites || 0 : 0 %>">
            </div>
            <div>
              <label class="input-label">Banheiros</label>
              <input type="number" name="banheiros" class="input" min="0" value="<%= imovel ? imovel.banheiros || 0 : 0 %>">
            </div>
            <div>
              <label class="input-label">Vagas de Garagem</label>
              <input type="number" name="vagas_garagem" class="input" min="0" value="<%= imovel ? imovel.vagas_garagem || 0 : 0 %>">
            </div>
          </div>

          <h3 style="font-family:var(--font-serif);font-size:var(--title-lg);margin:1.5rem 0 1.5rem;padding:1rem 0;border-top:1px solid var(--surface-container-high);border-bottom:1px solid var(--surface-container-high);">Localização</h3>

          <div class="admin-form__grid">
            <div class="admin-form__full">
              <label class="input-label">Endereço</label>
              <input type="text" name="endereco" class="input" value="<%= imovel ? imovel.endereco || '' : '' %>" placeholder="Rua, número">
            </div>
            <div>
              <label class="input-label">Bairro</label>
              <input type="text" name="bairro" class="input" value="<%= imovel ? imovel.bairro || '' : '' %>">
            </div>
            <div>
              <label class="input-label">Cidade</label>
              <input type="text" name="cidade" class="input" value="<%= imovel ? imovel.cidade || 'Maringá' : 'Maringá' %>">
            </div>
            <div>
              <label class="input-label">Estado</label>
              <input type="text" name="estado" class="input" maxlength="2" value="<%= imovel ? imovel.estado || 'PR' : 'PR' %>">
            </div>
            <div>
              <label class="input-label">CEP</label>
              <input type="text" name="cep" class="input" value="<%= imovel ? imovel.cep || '' : '' %>" placeholder="00000-000">
            </div>
            <div>
              <label class="input-label">Andar</label>
              <input type="text" name="andar" class="input" value="<%= imovel ? imovel.andar || '' : '' %>" placeholder="Ex: 14">
            </div>
            <div>
              <label class="input-label">Apto / Lote / Sala</label>
              <input type="text" name="apto" class="input" value="<%= imovel ? imovel.apto || '' : '' %>" placeholder="Ex: 1403">
            </div>
          </div>

          <h3 style="font-family:var(--font-serif);font-size:var(--title-lg);margin:1.5rem 0 1.5rem;padding:1rem 0;border-top:1px solid var(--surface-container-high);border-bottom:1px solid var(--surface-container-high);">Configurações</h3>

          <div style="display:flex;gap:2rem;margin-bottom:1.5rem;flex-wrap:wrap;align-items:flex-start;">
            <% 
              const jaEhDestaque = imovel && imovel.destaque;
              const limiteBloqueado = !jaEhDestaque && totalDestaques >= 3;
            %>
            <div>
              <label <%- limiteBloqueado ? 'style="display:flex;align-items:center;gap:0.5rem;cursor:not-allowed;"' : 'style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;"' %>>
                <input type="checkbox" name="destaque" id="destaqueCheck"
                  <%= jaEhDestaque ? 'checked' : '' %>
                  <%= limiteBloqueado ? 'disabled' : '' %>
                >
                <span class="input-label" <%- limiteBloqueado ? 'style="margin-bottom:0;opacity:0.45;"' : 'style="margin-bottom:0;opacity:1;"' %>>Imóvel Destaque</span>
              </label>
              <% if (limiteBloqueado) { %>
                <div style="margin-top:6px;font-size:0.7rem;color:var(--on-surface-variant);max-width:240px;line-height:1.4;">
                  Limite atingido — remova um destaque no <a href="/admin/dashboard" style="color:var(--primary);font-weight:600;">Dashboard</a> para adicionar outro.
                </div>
              <% } %>
            </div>
            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
              <input type="checkbox" name="novo" <%= imovel && imovel.novo ? 'checked' : '' %>>
              <span class="input-label" style="margin-bottom:0;">Marcar como Novo</span>
            </label>
            <% if (imovel) { %>
            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
              <input type="checkbox" name="ativo" <%= imovel.ativo ? 'checked' : '' %>>
              <span class="input-label" style="margin-bottom:0;">Imóvel Ativo</span>
            </label>
            <% } %>
          </div>

          <div style="display:flex;gap:1rem;margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--surface-container-high);">
            <button type="submit" class="btn btn--primary"><%= imovel ? 'Salvar Alterações' : 'Cadastrar Imóvel' %></button>
            <a href="/admin/imoveis" class="btn btn--secondary">Cancelar</a>
          </div>
        </div>
      </form>
    </div>
  </main>
</div>
<script src="/js/admin.js"></script>
<script>
// ── Prepara fotos antes do submit ──
document.querySelector('form[action*="/admin/imoveis"]')?.addEventListener('submit', function() {
  prepararFotosParaSubmit();
  serializarOrdemFotos();
});

// ── Drag & Drop — Fotos existentes (fotosAtuais) ──
(function() {
  const grid = document.getElementById('fotosAtuais');
  if (!grid) return;
  let dragged = null;

  grid.addEventListener('dragstart', e => {
    dragged = e.target.closest('.foto-drag-item');
    if (!dragged) return;
    setTimeout(() => dragged.classList.add('foto-dragging'), 0);
  });

  grid.addEventListener('dragend', () => {
    if (dragged) dragged.classList.remove('foto-dragging');
    grid.querySelectorAll('.foto-drag-item').forEach(el => el.classList.remove('foto-drag-over'));
    dragged = null;
    atualizarBadgePrincipal(grid, '.foto-drag-item');
  });

  grid.addEventListener('dragover', e => {
    e.preventDefault();
    const target = e.target.closest('.foto-drag-item');
    if (!target || target === dragged) return;
    grid.querySelectorAll('.foto-drag-item').forEach(el => el.classList.remove('foto-drag-over'));
    target.classList.add('foto-drag-over');
    const rect = target.getBoundingClientRect();
    if (e.clientX < rect.left + rect.width / 2) {
      grid.insertBefore(dragged, target);
    } else {
      grid.insertBefore(dragged, target.nextSibling);
    }
  });

  grid.addEventListener('dragleave', e => {
    const t = e.target.closest('.foto-drag-item');
    if (t) t.classList.remove('foto-drag-over');
  });
})();

// Atualiza qual item recebe a badge PRINCIPAL (sempre o primeiro)
function atualizarBadgePrincipal(grid, selector) {
  const items = grid.querySelectorAll(selector);
  items.forEach((el, i) => {
    const badge = el.querySelector('.foto-principal-badge');
    if (badge) badge.classList.toggle('foto-principal-badge--on', i === 0);
  });
}

// Serializa ordem atual dos IDs das fotos existentes no hidden input
function serializarOrdemFotos() {
  const grid = document.getElementById('fotosAtuais');
  if (!grid) return;
  const ids = Array.from(grid.querySelectorAll('.foto-drag-item'))
    .map(el => el.id.replace('foto-', ''))
    .filter(Boolean);
  const inp = document.getElementById('fotosOrdemInput');
  if (inp) inp.value = JSON.stringify(ids);
}

// ── Drag & Drop — Fotos da pasta (pastaFotosGrid) ──
function initDragPastaGrid() {
  const grid = document.getElementById('pastaFotosGrid');
  if (!grid) return;
  let dragged = null;

  grid.addEventListener('dragstart', e => {
    dragged = e.target.closest('[data-idx]');
    if (!dragged) return;
    setTimeout(() => dragged.classList.add('foto-dragging'), 0);
  });

  grid.addEventListener('dragend', () => {
    if (dragged) dragged.classList.remove('foto-dragging');
    grid.querySelectorAll('[data-idx]').forEach(el => el.classList.remove('foto-drag-over'));
    dragged = null;
    // Sincroniza _pastaFotos com a ordem visual atual
    const novaOrdem = Array.from(grid.querySelectorAll('[data-idx]')).map(el => parseInt(el.dataset.idx));
    _pastaFotos = novaOrdem.map(i => _pastaFotos[i]);
    // Reindexa data-idx
    Array.from(grid.querySelectorAll('[data-idx]')).forEach((el, i) => { el.dataset.idx = i; });
    atualizarBadgePrincipal(grid, '[data-idx]');
  });

  grid.addEventListener('dragover', e => {
    e.preventDefault();
    const target = e.target.closest('[data-idx]');
    if (!target || target === dragged) return;
    grid.querySelectorAll('[data-idx]').forEach(el => el.classList.remove('foto-drag-over'));
    target.classList.add('foto-drag-over');
    const rect = target.getBoundingClientRect();
    if (e.clientX < rect.left + rect.width / 2) {
      grid.insertBefore(dragged, target);
    } else {
      grid.insertBefore(dragged, target.nextSibling);
    }
  });

  grid.addEventListener('dragleave', e => {
    const t = e.target.closest('[data-idx]');
    if (t) t.classList.remove('foto-drag-over');
  });
}
// Inicia o drag da pasta sempre que renderizarFotos for chamada
const _renderizarFotosOrig = typeof renderizarFotos === 'function' ? renderizarFotos : null;
// (initDragPastaGrid é chamado dentro de renderizarFotos — ver patch abaixo)

// ── Conversão de Área ha ↔ m² ──
function syncArea(tipo) {
  const display = document.getElementById('areaTotal_display');
  const unit    = document.getElementById('areaTotal_unit');
  const hidden  = document.getElementById('area_total_hidden');
  const unitHid = document.getElementById('unidade_area_hidden');
  if (!display || !unit || !hidden) return;

  const val = parseFloat(display.value);
  if (isNaN(val) || display.value === '') {
    hidden.value = '';
  } else if (unit.value === 'ha') {
    hidden.value = (val * 10000).toFixed(2); // 1 ha = 10.000 m²
  } else {
    hidden.value = val;
  }
  if (unitHid) unitHid.value = unit.value === 'ha' ? 'ha' : 'm2';
}
// Inicializa ao carregar
document.addEventListener('DOMContentLoaded', () => syncArea('total'));

// ── Sob Consulta ──
function toggleSobConsulta(cb) {
  const input = document.getElementById('precoInput');
  const hidden = document.getElementById('precoHidden');
  if (cb.checked) {
    input.dataset.prevValue = input.value;
    input.value = '';
    input.disabled = true;
    hidden.value = '0';
  } else {
    input.value = input.dataset.prevValue || '';
    input.disabled = false;
    hidden.value = input.value;
    input.focus();
  }
}

// ── Fotos da pasta selecionadas (File[]) e qual é a principal ──
let _pastaFotos = [];
let _principalIdx = 0;

// Preenche campos do formulário com dados extraídos
function preencherCampos(d) {
  const set = (name, val) => {
    if (val == null || val === '') return;
    const el = document.querySelector(`[name="${name}"]`);
    if (!el) return;
    el.value = val;
  };
  set('titulo', d.titulo); set('tipo', d.tipo); set('finalidade', d.finalidade);
  // Preço: se o documento trouxer valor, desmarca "sob consulta" e preenche
  if (d.preco != null && d.preco > 0) {
    const cb = document.getElementById('sobConsultaCheck');
    if (cb && cb.checked) toggleSobConsulta({ checked: false }), cb.checked = false;
    document.getElementById('precoInput').value = d.preco;
    document.getElementById('precoHidden').value = d.preco;
  }
  set('quartos', d.quartos); set('suites', d.suites);
  set('banheiros', d.banheiros); set('vagas_garagem', d.vagas_garagem);
  set('area_total', d.area_total); set('area_construida', d.area_construida);
  set('endereco', d.endereco); set('bairro', d.bairro);
  set('cidade', d.cidade); set('estado', d.estado);
  set('andar', d.andar); set('apto', d.apto);
  set('descricao', d.descricao);
}

// Chama API de parse e retorna os dados extraídos (timeout: 10s)
async function chamarParseDoc(file) {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), 10000);
  try {
    const fd = new FormData();
    fd.append('ficha', file);
    const res = await fetch('/admin/imoveis/parse-doc', { method: 'POST', headers: { 'x-csrf-token': window._csrf || '' }, body: fd, signal: controller.signal });
    clearTimeout(timer);
    const json = await res.json();
    if (!json.success) throw new Error(json.error || 'Erro ao processar documento');
    return json.data;
  } catch (e) {
    clearTimeout(timer);
    if (e.name === 'AbortError') throw new Error('Tempo esgotado ao ler o documento (>20s)');
    throw e;
  }
}

// Mostra status
function setStatus(msg, tipo) {
  const el = document.getElementById('fichaStatus');
  el.style.display = 'block';
  el.style.background = tipo === 'ok' ? '#d1fae5' : tipo === 'erro' ? '#fee2e2' : 'var(--surface-container)';
  el.style.color     = tipo === 'ok' ? '#065f46' : tipo === 'erro' ? '#991b1b' : 'var(--on-surface-variant)';
  el.textContent = msg;
}

// Renderiza grid de fotos com drag para reordenar (primeira = principal)
function renderizarFotos(files) {
  _pastaFotos = files;
  const wrap = document.getElementById('pastaFotosWrap');
  const grid = document.getElementById('pastaFotosGrid');
  if (!files.length) { wrap.style.display = 'none'; return; }
  document.getElementById('uploadFotosManual').style.display = 'none';
  wrap.style.display = 'block';
  grid.innerHTML = '';
  const frag = document.createDocumentFragment();
  files.forEach((file, i) => {
    const url = URL.createObjectURL(file);
    const div = document.createElement('div');
    div.className = 'foto-drag-item';
    div.style.cssText = 'position:relative;border-radius:8px;overflow:hidden;aspect-ratio:1;';
    div.dataset.idx = i;
    div.draggable = true;
    const img = document.createElement('img');
    img.src = url;
    img.loading = 'lazy';
    img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
    const badge = document.createElement('div');
    badge.className = 'foto-principal-badge' + (i === 0 ? ' foto-principal-badge--on' : '');
    badge.textContent = 'PRINCIPAL';
    div.appendChild(img);
    div.appendChild(badge);
    frag.appendChild(div);
  });
  grid.appendChild(frag);
  initDragPastaGrid();
}

// Constrói o FileList ordenado UMA UNICA VEZ, logo antes do submit
// Isso evita travar o browser ao carregar a pasta ou trocar de principal
function prepararFotosParaSubmit() {
  if (!_pastaFotos.length) return;
  // _pastaFotos já está na ordem correta após drag — primeira = principal
  const dt = new DataTransfer();
  _pastaFotos.forEach(f => dt.items.add(f));
  document.getElementById('fotosInput').files = dt.files;
}

// ── Carregar pasta ──
async function processarPasta(input) {
  const files = Array.from(input.files);
  if (!files.length) return;

  const docFile    = files.find(f => /\.(pdf|docx)$/i.test(f.name));
  const imageFiles = files.filter(f => /\.(jpe?g|png|webp)$/i.test(f.name));

  // Carrega as fotos imediatamente — não espera o documento
  if (imageFiles.length) {
    renderizarFotos(imageFiles);
  }

  let msgs = [];

  // Processar documento em paralelo
  if (docFile) {
    setStatus(`Lendo ficha (${docFile.name})…`, 'carregando');
    try {
      const dados = await chamarParseDoc(docFile);
      preencherCampos(dados);
      msgs.push(`✓ Ficha lida (${docFile.name})`);
    } catch (e) {
      msgs.push(`⚠ Erro na ficha: ${e.message}`);
    }
  } else {
    msgs.push('⚠ Nenhuma ficha (PDF/DOCX) na pasta');
  }

  if (imageFiles.length) {
    msgs.push(`✓ ${imageFiles.length} foto(s) — clique para definir a principal`);
  } else {
    msgs.push('⚠ Nenhuma foto encontrada na pasta');
  }

  setStatus(msgs.join(' · '), imageFiles.length ? 'ok' : 'erro');
  input.value = '';
}

// ── Carregar só a ficha ──
async function processarFicha(input) {
  const file = input.files[0];
  if (!file) return;
  setStatus('Processando arquivo…', 'carregando');
  try {
    const dados = await chamarParseDoc(file);
    preencherCampos(dados);
    setStatus('✓ Campos preenchidos com sucesso! Revise antes de salvar.', 'ok');
  } catch (err) {
    setStatus('✕ ' + err.message, 'erro');
  }
  input.value = '';
}
</script>
