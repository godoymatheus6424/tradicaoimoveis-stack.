<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="detalhes-content">
  <div class="container">

    <div class="detalhes-breadcrumb" style="padding-top:var(--space-xl);margin-bottom:var(--space-lg);">
      <a href="/">Home</a> &rsaquo; <a href="/imoveis">Imóveis</a> &rsaquo; <%= imovel.tipo %>
    </div>

    <div class="detalhes-layout">

      <!-- ESQUERDA: Galeria -->
      <div class="detalhes-galeria">
        <% if (fotos && fotos.length > 0) { %>
        <div class="galeria__principal" id="galeriaPrincipal" onclick="abrirLightbox(fotoAtualIdx)">
          <img id="fotoAtiva" src="<%= fotos[0].path %>" alt="<%= imovel.titulo %>">
        </div>
        <% if (fotos.length > 1) { %>
        <div style="position:relative;display:flex;align-items:center;gap:8px;margin-top:var(--space-xs);">
          <button id="thumbPrev" onclick="thumbNav(-1)" style="flex-shrink:0;width:32px;height:32px;border-radius:50%;border:1.5px solid var(--outline-variant);background:var(--surface);display:flex;align-items:center;justify-content:center;cursor:pointer;" onmouseenter="this.style.background='var(--surface-container-high)'" onmouseleave="this.style.background='var(--surface)'">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div style="overflow:hidden;flex:1;">
            <div id="thumbTrack" style="display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-xs);">
              <% fotos.forEach(function(foto, i) { %>
              <div class="galeria__thumb <%= i === 0 ? 'galeria__thumb--active' : '' %>" data-idx="<%= i %>" onclick="trocarFoto('<%= foto.path %>', this, <%= i %>)" style="display:none;">
                <img src="<%= foto.path %>" alt="Foto <%= i + 1 %>">
              </div>
              <% }) %>
            </div>
          </div>
          <button id="thumbNext" onclick="thumbNav(1)" style="flex-shrink:0;width:32px;height:32px;border-radius:50%;border:1.5px solid var(--outline-variant);background:var(--surface);display:flex;align-items:center;justify-content:center;cursor:pointer;" onmouseenter="this.style.background='var(--surface-container-high)'" onmouseleave="this.style.background='var(--surface)'">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
        <div id="thumbCounter" style="text-align:center;font-size:var(--label-sm);color:var(--on-surface-variant);margin-top:6px;"></div>
        <% } %>
        <% } else { %>
        <div style="aspect-ratio:4/3;background:var(--surface-container-high);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;">
          <span style="font-size:5rem;">🏠</span>
        </div>
        <% } %>
      </div>

      <!-- DIREITA: Informações + Contato -->
      <div class="detalhes-info">

        <!-- Tags -->
        <div class="detalhes-header__tags" style="margin-bottom:var(--space-md);">
          <span class="detalhes-tag detalhes-tag--tipo"><%= imovel.tipo %></span>
          <span class="detalhes-tag detalhes-tag--finalidade"><%= imovel.finalidade === 'locacao' ? 'Aluguel' : 'Venda' %></span>
          <span class="detalhes-tag detalhes-tag--ref">Ref: #<%= String(imovel.id).padStart(4,'0') %></span>
          <% if (imovel.destaque) { %><span class="detalhes-tag detalhes-tag--destaque">Destaque</span><% } %>
        </div>

        <!-- Título -->
        <h1 class="detalhes-header__title" style="margin-bottom:var(--space-sm);"><%= imovel.titulo %></h1>

        <!-- Endereço -->
        <% if (imovel.endereco || imovel.bairro || imovel.cidade) { %>
        <div class="detalhes-header__address" style="margin-bottom:var(--space-lg);">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
          <%= [imovel.endereco, imovel.bairro, imovel.cidade, imovel.estado].filter(Boolean).join(', ') %>
        </div>
        <% } %>

        <!-- Preço -->
        <div style="margin-bottom:var(--space-xl);padding-bottom:var(--space-lg);border-bottom:1px solid var(--outline-variant);">
          <div class="detalhes-header__price-label"><%= imovel.finalidade === 'aluguel' ? 'Aluguel' : 'Valor' %></div>
          <div class="detalhes-header__price-value"><%= imovel.preco_formatado %></div>
        </div>

        <!-- Specs inline -->
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-bottom:var(--space-xl);padding-bottom:var(--space-lg);border-bottom:1px solid var(--outline-variant);">
          <% if (imovel.quartos > 0) { %>
          <div style="display:flex;align-items:center;gap:0.4rem;font-size:var(--label-md);color:var(--on-surface-variant);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.8"><path d="M3 20V8a2 2 0 012-2h14a2 2 0 012 2v12"/><path d="M3 14h18"/><path d="M7 14v6"/><path d="M17 14v6"/></svg>
            <strong style="color:var(--on-surface);"><%= imovel.quartos %></strong> Quartos
          </div>
          <% } %>
          <% if (imovel.suites > 0) { %>
          <div style="display:flex;align-items:center;gap:0.4rem;font-size:var(--label-md);color:var(--on-surface-variant);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.8"><path d="M3 20V10a2 2 0 012-2h14a2 2 0 012 2v10"/><path d="M3 14h18"/><path d="M9 8V6a1 1 0 011-1h4a1 1 0 011 1v2"/><path d="M7 20v-6"/><path d="M17 20v-6"/></svg>
            <strong style="color:var(--on-surface);"><%= imovel.suites %></strong> Suítes
          </div>
          <% } %>
          <% if (imovel.banheiros > 0) { %>
          <div style="display:flex;align-items:center;gap:0.4rem;font-size:var(--label-md);color:var(--on-surface-variant);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.8"><path d="M4 12h16"/><path d="M4 12V6a2 2 0 012-2h4a2 2 0 012 2v6"/><rect x="2" y="12" width="20" height="4" rx="1"/><path d="M6 20v-4"/><path d="M18 20v-4"/></svg>
            <strong style="color:var(--on-surface);"><%= imovel.banheiros %></strong> Banheiros
          </div>
          <% } %>
          <% if (imovel.vagas_garagem > 0) { %>
          <div style="display:flex;align-items:center;gap:0.4rem;font-size:var(--label-md);color:var(--on-surface-variant);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.8"><rect x="1" y="9" width="22" height="11" rx="2"/><path d="M7 9V7a5 5 0 0110 0v2"/></svg>
            <strong style="color:var(--on-surface);"><%= imovel.vagas_garagem %></strong> Vagas
          </div>
          <% } %>
          <% if (imovel.area_total) { %>
          <div style="display:flex;align-items:center;gap:0.4rem;font-size:var(--label-md);color:var(--on-surface-variant);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18"/><path d="M9 3v18"/></svg>
            <strong style="color:var(--on-surface);"><%= Math.round(imovel.area_total) %> m²</strong> Total
          </div>
          <% } %>
          <% if (imovel.area_construida) { %>
          <div style="display:flex;align-items:center;gap:0.4rem;font-size:var(--label-md);color:var(--on-surface-variant);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.8"><path d="M2 20h20"/><path d="M6 20V8l6-6 6 6v12"/><path d="M10 20v-6h4v6"/></svg>
            <strong style="color:var(--on-surface);"><%= Math.round(imovel.area_construida) %> m²</strong> Construído
          </div>
          <% } %>
        </div>

        <!-- Descrição -->
        <% if (imovel.descricao) { %>
        <div style="margin-bottom:var(--space-xl);padding-bottom:var(--space-lg);border-bottom:1px solid var(--outline-variant);">
          <h3 style="font-family:var(--font-serif);font-size:var(--title-md);margin-bottom:0.75rem;">Descrição</h3>
          <p style="color:var(--on-surface-variant);line-height:1.8;white-space:pre-line;font-size:var(--label-md);"><%= imovel.descricao %></p>
        </div>
        <% } %>

        <!-- Botões de contato -->
        <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:var(--space-xl);">
          <a href="https://wa.me/5544998870006?text=Olá! Tenho interesse no imóvel: <%= encodeURIComponent(imovel.titulo) %>" target="_blank" class="btn btn--whatsapp btn--full">WhatsApp</a>
          <a href="/contato?imovel=<%= imovel.id %>" class="btn btn--secondary btn--full">Agendar Visita</a>
        </div>

        <!-- Formulário de contato -->
        <div style="padding:1.5rem;background:var(--surface-container-low);border-radius:var(--radius-md);">
          <div style="font-family:var(--font-serif);font-size:var(--title-md);margin-bottom:1rem;">Enviar Mensagem</div>
          <form id="formContato">
            <input type="hidden" name="imovel_id" value="<%= imovel.id %>">
            <div class="input-group">
              <input type="text" class="input" name="nome" placeholder="Seu nome" required>
            </div>
            <div class="input-group">
              <input type="email" class="input" name="email" placeholder="Seu e-mail" required>
            </div>
            <div class="input-group">
              <input type="tel" class="input" name="telefone" placeholder="Telefone">
            </div>
            <div class="input-group">
              <textarea class="input" name="mensagem" rows="3">Olá! Tenho interesse no imóvel <%= imovel.titulo %>.</textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--full">Enviar Mensagem</button>
            <div id="contatoMsg" style="margin-top:0.75rem;font-size:var(--label-md);text-align:center;"></div>
          </form>
        </div>

      </div><!-- /detalhes-info -->
    </div><!-- /detalhes-layout -->
  </div>
</section>

<!-- Relacionados -->
<% if (relacionados && relacionados.length > 0) { %>
<section class="relacionados">
  <div class="container">
    <div class="section__header fade-in">
      <div class="section__eyebrow">Veja Também</div>
      <h2 class="section__title">Imóveis Relacionados</h2>
    </div>
    <div class="grid-3 fade-in">
      <% relacionados.forEach(function(im) { %>
      <div class="card">
        <div class="card__image">
          <% if (im.foto_principal) { %>
            <img src="<%= im.foto_principal %>" alt="<%= im.titulo %>">
          <% } else { %>
            <div style="width:100%;height:100%;background:var(--surface-container-high);display:flex;align-items:center;justify-content:center;font-size:3rem;">🏠</div>
          <% } %>
        </div>
        <div class="card__body">
          <div class="card__title"><%= im.titulo %></div>
          <div class="card__price"><%= im.preco_formatado %></div>
          <a href="/imovel/<%= im.id %>" class="btn btn--ghost btn--sm">Saiba Mais</a>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <button class="lightbox__close" onclick="fecharLightbox()">✕</button>
  <button class="lightbox__nav lightbox__nav--prev" onclick="navLightbox(-1)">&#8249;</button>
  <img class="lightbox__img" id="lightboxImg" src="" alt="">
  <button class="lightbox__nav lightbox__nav--next" onclick="navLightbox(1)">&#8250;</button>
</div>

<%- include('partials/footer') %>

<script>
const fotos = <%- JSON.stringify(fotos.map(f => f.path)) %>;
let fotoAtualIdx = 0;

function trocarFoto(src, el, idx) {
  document.getElementById('fotoAtiva').src = src;
  fotoAtualIdx = idx;
  document.querySelectorAll('.galeria__thumb').forEach(t => t.classList.remove('galeria__thumb--active'));
  el.classList.add('galeria__thumb--active');
}

function abrirLightbox(idx) {
  fotoAtualIdx = idx;
  document.getElementById('lightboxImg').src = fotos[idx];
  document.getElementById('lightbox').classList.add('lightbox--open');
}

function fecharLightbox() {
  document.getElementById('lightbox').classList.remove('lightbox--open');
}

function navLightbox(dir) {
  fotoAtualIdx = (fotoAtualIdx + dir + fotos.length) % fotos.length;
  document.getElementById('lightboxImg').src = fotos[fotoAtualIdx];
}

document.getElementById('lightbox').addEventListener('click', function(e) {
  if (e.target === this) fecharLightbox();
});

document.addEventListener('keydown', function(e) {
  if (!document.getElementById('lightbox').classList.contains('lightbox--open')) return;
  if (e.key === 'Escape') fecharLightbox();
  if (e.key === 'ArrowLeft') navLightbox(-1);
  if (e.key === 'ArrowRight') navLightbox(1);
});

// Carrossel de thumbs (4 por página)
(function() {
  const thumbs = Array.from(document.querySelectorAll('#thumbTrack .galeria__thumb'));
  if (!thumbs.length) return;
  const PER_PAGE = 4;
  let page = 0;
  const total = Math.ceil(thumbs.length / PER_PAGE);

  function render() {
    thumbs.forEach((t, i) => {
      t.style.display = (i >= page * PER_PAGE && i < (page + 1) * PER_PAGE) ? '' : 'none';
    });
    const counter = document.getElementById('thumbCounter');
    if (counter && total > 1) counter.textContent = `${page + 1} / ${total}`;
    else if (counter) counter.textContent = '';
    const prev = document.getElementById('thumbPrev');
    const next = document.getElementById('thumbNext');
    if (prev) prev.style.opacity = page === 0 ? '0.3' : '1';
    if (next) next.style.opacity = page === total - 1 ? '0.3' : '1';
  }

  window.thumbNav = function(dir) {
    page = Math.max(0, Math.min(total - 1, page + dir));
    render();
  };

  const _orig = window.trocarFoto;
  window.trocarFoto = function(src, el, idx) {
    _orig(src, el, idx);
    const newPage = Math.floor(idx / PER_PAGE);
    if (newPage !== page) { page = newPage; render(); }
  };

  render();
})();
</script>
<script src="/js/main.js"></script>
<script src="/js/contato.js"></script>
</body>
</html>
